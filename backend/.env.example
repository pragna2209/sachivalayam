# ---------------------------------------------------------------------------
# Sachivalayam Backend - Environment Variables
# Copy this file to .env and fill in real values. Never commit the real .env.
# ---------------------------------------------------------------------------

# Server
NODE_ENV=development
PORT=5000
API_BASE_PATH=/api/v1

# MongoDB (Atlas connection string - Render does not natively host MongoDB)
MONGODB_URI=MONGODB_URI=mongodb+srv://pragna:ramamurthy@cluster0.tg0alwe.mongodb.net/sachivalayam?retryWrites=true&w=majority&appName=Cluster0

# JWT
JWT_ACCESS_SECRET=replace_with_a_long_random_string_for_access_tokens
JWT_REFRESH_SECRET=replace_with_a_long_random_string_for_refresh_tokens
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OTP
OTP_LENGTH=6
OTP_EXPIRES_IN_MINUTES=5
OTP_MAX_REQUESTS_PER_WINDOW=3
OTP_REQUEST_WINDOW_MINUTES=10
OTP_MAX_VERIFY_ATTEMPTS=5

# Anonymous complaint PIN
ANONYMOUS_PIN_LENGTH=6

# Reopen policy
REOPEN_WINDOW_DAYS=7
REOPEN_MAX_COUNT=2

# Escalation thresholds (days)
ESCALATION_ASSIGNMENT_BREACH_DAYS=2
ESCALATION_MANDAL_LEVEL1_DAYS=7
ESCALATION_DISTRICT_LEVEL2_DAYS=15
ESCALATION_SCHEDULER_CRON=*/15 * * * *

# File upload limits (bytes)
MAX_IMAGE_SIZE_BYTES=10485760
MAX_DOCUMENT_SIZE_BYTES=20971520
MAX_VIDEO_SIZE_BYTES=52428800

# Local upload staging directory (files are moved to object storage after validation)
UPLOAD_TEMP_DIR=./tmp/uploads

# Object storage (Cloudinary example - swap for any S3-compatible provider)
STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email provider (SMTP example)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_NAME=Sachivalayam Grievance System
SMTP_FROM_EMAIL=no-reply@example.gov.in

# SMS provider (pluggable - sandbox stub by default)
SMS_PROVIDER=sandbox
SMS_API_KEY=
SMS_SENDER_ID=SCMSYS

# WhatsApp provider (pluggable - sandbox stub by default)
WHATSAPP_PROVIDER=sandbox
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=300

# Logging
LOG_LEVEL=info
