# API base URL. In development, Vite's dev-server proxy (see vite.config.js)
# forwards /api requests to VITE_API_PROXY_TARGET, so this can usually stay
# as the default relative path. Set an absolute URL for production builds
# pointing at the deployed sachivalayam-api Render service.
VITE_API_BASE_URL=/api/v1

# Only used by the Vite dev-server proxy, not bundled into the production build.
VITE_API_PROXY_TARGET=http://localhost:5000
